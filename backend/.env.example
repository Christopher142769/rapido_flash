# Copier vers backend/.env et adapter
# Ce fichier est chargé après le .env à la racine du repo : les valeurs ici priment.

# Base locale (défaut aussi dans server.js si MONGODB_URI est absent)
MONGODB_URI=mongodb://127.0.0.1:27017/rapido_flash

# Pour Atlas, remplace par ta chaîne mongodb+srv://...
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/rapido_flash?retryWrites=true&w=majority

JWT_SECRET=secret_key
PORT=5000

# CORS — origines du frontend (une par ligne ; ajoute rapido.online si utilisé)
FRONTEND_URL_1=https://rapido.bj
FRONTEND_URL_2=https://rapido.online

# FedaPay — clé secrète (serveur uniquement, jamais dans le frontend React)
# FEDAPAY_SECRET_KEY=sk_live_...
