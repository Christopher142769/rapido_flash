# Copier vers backend/.env et adapter
# Ce fichier est chargé après le .env à la racine du repo : les valeurs ici priment.

# Base locale (défaut aussi dans server.js si MONGODB_URI est absent)
MONGODB_URI=mongodb://127.0.0.1:27017/rapido_flash

# Pour Atlas, remplace par ta chaîne mongodb+srv://...
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/rapido_flash?retryWrites=true&w=majority

JWT_SECRET=secret_key
PORT=5000

# Google Sign-In — option A : une seule variable (même client Web que REACT_APP_GOOGLE_CLIENT_ID dans le frontend).
# GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
# Optionnel seulement si tu crées un 2e client Web dédié : GOOGLE_CLIENT_ID_CAPACITOR=...

# CORS — origines du frontend (une par ligne ; ajoute rapido.online si utilisé)
FRONTEND_URL_1=https://rapido.bj
FRONTEND_URL_2=https://rapido.online
# Les apps Capacitor (APK) utilisent en plus https://localhost / capacitor://localhost : géré dans server.js.

# FedaPay — clé secrète (serveur uniquement, jamais dans le frontend React)
# FEDAPAY_SECRET_KEY=sk_live_...

# Web Push (notifications hors onglet / écran verrouillé — Chrome, Edge, Firefox, Android)
# Générer les clés : npx web-push generate-vapid-keys
# Puis coller la public dans VAPID_PUBLIC_KEY et la private dans VAPID_PRIVATE_KEY (une seule ligne chacune).
# VAPID_SUBJECT=mailto:contact@ton-domaine.bj
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...

# App mobile (Expo / React Native) : les notifications utilisent l’API Expo Push côté serveur.
# Aucune variable supplémentaire obligatoire ici ; les jetons sont enregistrés via POST /api/push/mobile/register.

# Admin plateforme (maintenance dashboard + e-mails nouvelles commandes Shop / app)
# PLATFORM_ADMIN_EMAIL=rapido002026@gmail.com,autre@example.com

# Alertes WhatsApp nouvelles commandes → équipe Rapido (défaut +229 40 39 39 94)
# RAPIDO_WHATSAPP=22940393994
# Option A — WhatsApp Cloud API (Meta Business) — requis pour messages automatiques aux clients :
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=   # ID Meta du numéro +229 40 39 39 94
# WHATSAPP_CLIENT_AUTO_MESSAGE=true  # false pour désactiver l’envoi auto aux clients
# WHATSAPP_SKIP_CONTACT_CHECK=false  # true = envoyer sans vérifier si le numéro est sur WhatsApp
# WHATSAPP_ORDER_TEMPLATE_NAME=rapido_commande_confirmee
# WHATSAPP_ORDER_TEMPLATE_LANG=fr
# Option B — CallMeBot (alertes équipe uniquement) : https://www.callmebot.com/blog/free-api-whatsapp-messages/
# CALLMEBOT_WHATSAPP_APIKEY=

# FCM — app Capacitor (Android/iOS avec Firebase) : envoi serveur via Firebase Admin.
# Fichier JSON compte de service (voir secrets/firebase/README.txt — ne pas committer le JSON) :
# FCM_SERVICE_ACCOUNT_PATH=./secrets/firebase/service-account.json
# cwd = racine du repo si tu lances le backend depuis la racine. Chemin absolu possible.
# Render : montage « Secret file », FCM_SERVICE_ACCOUNT_JSON (JSON sur une ligne), ou
# FCM_SERVICE_ACCOUNT_JSON_B64 (même JSON encodé en base64, pratique si guillemets / longueur posent problème).
# FCM_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Les jetons device sont enregistrés par l’app via POST /api/push/fcm/register (auth JWT).
# Sans FCM configuré + google-services.json dans l’APK, le téléphone ne reçoit pas les pushes en veille profonde (comportement « WhatsApp »).
