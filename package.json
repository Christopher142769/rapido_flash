{
  "name": "rapido-flash",
  "version": "1.0.0",
  "description": "Plateforme de livraison pour restaurant",
  "main": "server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "nodemon backend/server.js",
    "client": "cd frontend && npm start",
    "install-all": "npm install && cd frontend && npm install && cd ../mobile && npm install",
    "mobile": "cd mobile && npx expo start",
    "android:cap": "cd frontend && npm run android:studio",
    "create-admin": "node backend/scripts/createAdmin.js",
    "create-admin-direct": "node backend/scripts/createAdminDirect.js",
    "create-default-plats": "node backend/scripts/createDefaultPlats.js",
    "associate-all": "node backend/scripts/associateAllToRestaurant.js"
  },
  "keywords": [
    "delivery",
    "restaurant",
    "food"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.1",
    "firebase-admin": "^13.8.0",
    "google-auth-library": "^10.6.2",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.10.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "concurrently": "^8.2.0",
    "nodemon": "^3.0.1"
  }
}
