<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Android 12+ : fond blanc explicite + icône centrale (évite flash noir / icône système par défaut). -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:background">@drawable/splash_brand</item>
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
        <item name="android:windowSplashScreenBackground">@android:color/white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
    </style>
</resources>
