# Domaines publics (SEO : hreflang, alternates ; fallback si window indisponible)
REACT_APP_SITE_URL=https://www.rapido.bj
REACT_APP_SITE_URL_ALT=https://www.rapido.online

# API — local par défaut ; en prod : URL du backend (sans /api pour BASE_URL)
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_BASE_URL=http://localhost:5000

# Google Sign-In — option A (recommandé) : un seul client OAuth « Application Web » partout (site + APK).
# Même valeur côté backend : GOOGLE_CLIENT_ID=...
# Sur Android natif, REACT_APP_GOOGLE_CLIENT_ID est utilisé en priorité pour requestIdToken ; ne mets pas l’ID client *Android* dans REACT_APP_GOOGLE_CLIENT_ID_CAPACITOR.
# (REACT_APP_GOOGLE_CLIENT_ID_CAPACITOR reste optionnel, surtout iOS.)
# REACT_APP_GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
#
# Console Google → ce client Web → Origines JavaScript autorisées : uniquement des URL https si la console le impose.
# Pour Capacitor (androidScheme https dans capacitor.config.json), ajoute au minimum :
#   https://localhost
# ainsi que tes domaines publics (ex. https://www.rapido.bj, https://rapido.online, etc.).
# http://localhost et capacitor://localhost ne sont utiles que si la console les accepte ; sinon tu peux t’en passer.
#
# App Android (connexion Google native) : dans Firebase ou Google Cloud Console, pour le package bj.rapido.mobile,
# enregistre l’empreinte SHA-1 du keystore qui signe l’APK/AAB (release). Si l’app est sur le Play Store, ajoute aussi
# la SHA-1 « App signing key certificate » affichée dans Play Console → Intégrité de l’appli.
# Empreintes locales : npm run android:sha1 (lit android/keystore.properties ; sans fichier → debug).

# Build Capacitor / prod locale : copier les valeurs Render dans `.env.production` (non versionné si tu préfères).

# FedaPay — clé publique live (build-time). La clé secrète sk_live_… reste uniquement sur le backend (webhooks).
REACT_APP_FEDAPAY_PUBLIC_KEY=pk_live_jBJmnSPRPp37So-Hd5YwWrRh
