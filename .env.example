# Base de données (MongoDB local par défaut dans server.js si cette variable est absente)
# Tu peux aussi tout mettre dans backend/.env — il est chargé en second et écrase ces valeurs.
MONGODB_URI=mongodb://127.0.0.1:27017/rapido_flash

# JWT (à changer en production)
JWT_SECRET=votre_secret_jwt

# Serveur
PORT=5000

# --- Envoi d'emails (code de connexion) ---
# Si SMTP_HOST et SMTP_USER sont définis, les codes sont envoyés par email.
# Sinon, le code s'affiche dans la console du backend (dev).

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=mot_de_passe_smtp
MAIL_FROM=Rapido Flash <noreply@votredomaine.com>

# --- Suivi commande (WhatsApp) — frontend + alertes backend ---
# Chiffres avec indicatif pays, sans + (défaut : +229 40 31 75 68)
REACT_APP_RAPIDO_WHATSAPP=22940317568
# RAPIDO_WHATSAPP=22940317568
# Messages auto aux clients (Shop + app) — WhatsApp Cloud API Meta (numéro +229 40 31 75 68) :
# WHATSAPP_CLOUD_ACCESS_TOKEN=
# WHATSAPP_CLOUD_PHONE_NUMBER_ID=
# WHATSAPP_CLIENT_AUTO_MESSAGE=true
# WHATSAPP_ORDER_TEMPLATE_NAME=   # modèle Meta approuvé (recommandé en production)
# CALLMEBOT_WHATSAPP_APIKEY=      # alertes équipe uniquement
