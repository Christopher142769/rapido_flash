# Base de données
MONGODB_URI=mongodb://localhost:27017/rapido_flash

# JWT (à changer en production)
JWT_SECRET=votre_secret_jwt

# Serveur
PORT=5000

# --- Envoi d'emails (code de connexion) ---
# Si SMTP_HOST et SMTP_USER sont définis, les codes sont envoyés par email.
# Sinon, le code s'affiche dans la console du backend (dev).

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=votre@email.com
SMTP_PASS=mot_de_passe_smtp
MAIL_FROM=Rapido Flash <noreply@votredomaine.com>
